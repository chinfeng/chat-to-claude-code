# Upstream OpenAI-compatible provider base URL
UPSTREAM_BASE_URL=https://api.openai.com/v1

# API key - in passthrough mode, client key is forwarded upstream
API_KEY=

# Enable api_key passthrough (client key sent directly to upstream)
ENABLE_API_KEY_PASSTHROUGH=true

# Server port
PORT=8082

# Enable thinking/reasoning support
ENABLE_THINKING=true

# Default model to use when client sends an unmapped model
DEFAULT_MODEL=gpt-4o
